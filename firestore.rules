rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isResident() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'resident';
    }
    
    function isSecurity() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'security';
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function getUserSociety() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userDoc.societyId;
    }
    
    function getUserFlat() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userDoc.flatId;
    }
    
    // ==================== SOCIETIES ====================
    match /societies/{societyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // ==================== VISITORS ====================
      match /visitors/{visitorId} {
        allow read: if isAuthenticated() && 
                       (isSecurity() || isAdmin() || 
                        (isResident() && resource.data.hostFlatId == getUserFlat()));
        
        allow create: if isSecurity() && 
                         request.resource.data.keys().hasAll(['visitorName', 'hostFlatId', 'purpose']);
        
        allow update: if isSecurity() || 
                         (isResident() && resource.data.hostFlatId == getUserFlat());
        
        allow delete: if isAdmin() || isSecurity();
      }
      
      // ==================== NOTIFICATIONS ====================
      match /notifications/{notificationId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin() || isSecurity();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
      
      // ==================== COMPLAINTS ====================
      match /complaints/{complaintId} {
        allow read: if isAuthenticated();
        allow create: if isResident();
        allow update: if (resource.data.raisedBy == request.auth.uid) || isSecurity() || isAdmin();
        allow delete: if isAdmin();
      }
      
      // ==================== BOOKINGS ====================
      match /bookings/{bookingId} {
        allow read: if isAuthenticated();
        allow create: if isResident();
        allow update: if (resource.data.bookedBy == request.auth.uid) || isAdmin();
        allow delete: if isAdmin();
      }
      
      // ==================== ANNOUNCEMENTS ====================
      match /announcements/{announcementId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
      
      // ==================== PAYMENTS ====================
      match /payments/{paymentId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    
    // ==================== USERS ====================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if (request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
