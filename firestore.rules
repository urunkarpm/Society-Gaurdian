rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isResident() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'resident';
    }
    
    function isSecurity() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'security';
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isVendor() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }
    
    function isSocietyMember(societyId) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.societyId == societyId;
    }
    
    function isFlatMember(flatId, societyId) {
      let flat = get(/databases/$(database)/documents/societies/$(societyId)/flats/$(flatId));
      return flat.data.memberUids.hasAny([request.auth.uid]);
    }
    
    function isValidVisitorData(data) {
      return data.visitorName is string &&
             data.visitorName.size() > 0 &&
             data.purpose is string &&
             data.gateNumber is string &&
             data.status is string &&
             data.taggedBy is string &&
             data.taggedAt is timestamp;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSecurity() || isAdmin());
      allow write: if request.auth.uid == userId || isAdmin();
      allow update: if request.auth.uid == userId || isAdmin();
    }
    
    // Societies collection
    match /societies/{societyId} {
      allow read: if isAuthenticated() && isSocietyMember(societyId);
      allow write: if isAdmin();
      
      // Flats subcollection
      match /flats/{flatId} {
        allow read: if isAuthenticated() && (isFlatMember(flatId, societyId) || isSecurity() || isAdmin());
        allow write: if isAdmin();
        
        // Only admins can modify flat structure
        allow update: if isAdmin();
      }
      
      // Visitors subcollection - CORE FUNCTIONALITY
      match /visitors/{visitorId} {
        allow read: if isAuthenticated() && (
          // Security can read all visitors
          isSecurity() || 
          isAdmin() ||
          // Residents can read visitors for their flat
          (isResident() && resource.data.hostFlatId in 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.flatId)
        );
        
        // Security personnel can create visitors
        allow create: if isSecurity() && isValidVisitorData(request.resource.data);
        
        // Security and residents can update visitor status
        allow update: if isSecurity() || 
                         (isResident() && 
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                            'status', 'approvedBy', 'approvedAt', 'rejectedBy', 
                            'rejectionReason', 'rejectedAt'
                          ]));
        
        allow delete: if isAdmin();
      }
      
      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && isSocietyMember(societyId);
        allow create: if isAdmin() || isSecurity();
        allow update: if request.auth.uid == resource.data.userId;
      }
      
      // Complaints subcollection
      match /complaints/{complaintId} {
        allow read: if isAuthenticated() && (
          isSecurity() || 
          isAdmin() ||
          (isResident() && resource.data.raisedByUid == request.auth.uid) ||
          (resource.data.assignedToUid == request.auth.uid)
        );
        
        allow create: if isAuthenticated() && isSocietyMember(societyId) &&
                       request.resource.data.category is string &&
                       request.resource.data.title is string &&
                       request.resource.data.description is string;
        
        allow update: if isSecurity() || 
                         isAdmin() ||
                         (isResident() && resource.data.raisedByUid == request.auth.uid &&
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                            'status', 'rating', 'feedback', 'updates'
                          ]));
      }
      
      // Amenities subcollection
      match /amenities/{amenityId} {
        allow read: if isAuthenticated() && isSocietyMember(societyId);
        allow write: if isAdmin();
        
        match /bookings/{bookingId} {
          allow read: if isAuthenticated() && (
            isAdmin() ||
            (isResident() && (resource.data.bookedByUid == request.auth.uid ||
                              isFlatMember(resource.data.flatId, societyId)))
          );
          
          allow create: if isAuthenticated() && isSocietyMember(societyId) &&
                         request.resource.data.slotDate is timestamp &&
                         request.resource.data.bookedByUid == request.auth.uid;
          
          allow update: if isAdmin() ||
                         (isResident() && resource.data.bookedByUid == request.auth.uid &&
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                            'status', 'cancellationReason', 'cancelledAt'
                          ]));
        }
      }
      
      // Announcements subcollection
      match /announcements/{announcementId} {
        allow read: if isAuthenticated() && isSocietyMember(societyId);
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
      
      // Maintenance/Payments subcollection
      match /maintenance/{maintenanceId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isResident() && resource.data.flatId in 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.flatId)
        );
        allow write: if isAdmin();
      }
      
      match /payments/{paymentId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isResident() && resource.data.flatId in 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.flatId)
        );
        allow write: if isAdmin();
      }
      
      // Emergency subcollection
      match /emergency/{emergencyId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          isSecurity() ||
          resource.data.raisedByUid == request.auth.uid
        );
        
        allow create: if isAuthenticated() && isSocietyMember(societyId);
        
        allow update: if isAdmin() || isSecurity();
      }
    }
    
    // Cloud Functions logs (read-only for admins)
    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Audit logs collection
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }
  }
}
